{
  "name": "soft-hair",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS de gestão para salões de beleza brasileiros — monorepo Turborepo",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,yaml,yml,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,yaml,yml,json}\" --ignore-path .gitignore",
    "aiox:validate": "npx aiox-core@latest validate",
    "aiox:doctor": "npx aiox-core@latest doctor"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "supabase": "^2.93.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
