# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend (SoftHair app)
# --------------------------------------------

# Supabase — public (exposed to browser)
# Get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Appointment management JWT secret (Story 2.7)
# 32+ bytes of random data. Signs the links sent to clients for the
# /agendamento/{token} manage page (cancel + reschedule). Rotate it to
# invalidate every outstanding link at once.
# Generate with: openssl rand -base64 48
APPOINTMENT_TOKEN_SECRET=

# Resend transactional email (Story 2.4 + 2.7)
# If absent, the flow logs payloads and the UI shows a pending banner.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Site URL (used to build absolute links in emails)
NEXT_PUBLIC_SITE_URL=

# Supabase local (used by AIOX agents during development)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --------------------------------------------
# SoftHair external integrations
# --------------------------------------------

# WhatsApp Business API (Meta Cloud API — ADR-0001)
# Prerequisite: founder has verified Business Account on Meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Chatwoot self-hosted (messaging orchestration)
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=

# Nuvem Fiscal NFS-e (ADR-0002)
# OAuth 2.0 client credentials from https://app.nuvemfiscal.com.br
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=
NUVEM_FISCAL_BASE_URL=https://api.nuvemfiscal.com.br

# Inngest (jobs agendados)
# Get from https://app.inngest.com/settings/keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --------------------------------------------
# Observability (SoftHair app)
# --------------------------------------------

# Sentry DSN (client + server)
# Already defined below — keep single SENTRY_DSN var

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below
